generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Installation {
  id              String   @id @default(cuid())
  stripeAccountId String   @unique @map("stripe_account_id")
  accessToken     String   @map("access_token")
  country         String
  pricingModel    String   @default("flat") @map("pricing_model") // 'ltd' | 'outcome' | 'flat'
  vauEnabled      Boolean  @default(false) @map("vau_enabled")
  abuEnabled      Boolean  @default(false) @map("abu_enabled")
  smsEnabled      Boolean  @default(false) @map("sms_enabled")
  // Module 6: new Installation fields
  livemode              Boolean @default(true)
  accountEmail          String? @map("account_email")
  accountDisplayName    String? @map("account_display_name")
  cancelFlowEnabled     Boolean @default(false) @map("cancel_flow_enabled")
  reactivationEnabled   Boolean @default(false) @map("reactivation_enabled")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations (back references)
  failedPayments        FailedPayment[]
  eventsRaw             EventRaw[]
  recoveredMonthly      RecoveredMonthly[]
  usageTracking         UsageTracking[]
  ltdInventory          LtdInventory?
  metricsDaily          MetricsDaily[]
  cancelFlowConfig      CancelFlowConfig?
  cancelFlowSessions    CancelFlowSession[]
  pausedSubscriptions   PausedSubscription[]
  churnedCustomers      ChurnedCustomer[]
  reactivationCampaign  ReactivationCampaign?

  @@map("installations")
}

model FailedPayment {
  id              String    @id @default(cuid())
  installationId  String    @map("installation_id")
  customerEmail   String    @map("customer_email")
  amount          Decimal   @db.Decimal(10, 2)
  failureCode     String?   @map("failure_code")
  cardFingerprint String?   @map("card_fingerprint")
  status          String    @default("failed") @map("status")
  attemptCount    Int       @default(0) @map("attempt_count")
  retryWindowEnd  DateTime? @map("retry_window_end")
  nextRetryAt     DateTime? @map("next_retry_at")
  churnRiskScore       Int       @default(0) @map("churn_risk_score")
  discountOfferSentAt  DateTime? @map("discount_offer_sent_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  invoiceId            String?   @map("invoice_id")

  // Module 2: Recovery attribution
  recoveredAt         DateTime? @map("recovered_at")
  recoverySource      String?   @map("recovery_source") // 'card_update' | 'retry_engine' | 'auto_updater' | 'unknown'
  abandonedAt         DateTime? @map("abandoned_at")
  failedEmailSentAt   DateTime? @map("failed_email_sent_at")
  recoveryEmailSentAt DateTime? @map("recovery_email_sent_at")

  installation Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)
  retryLogs    RetryLog[]

  @@index([installationId])
  @@index([status])
  @@index([nextRetryAt])
  @@index([recoverySource])
  @@map("failed_payments")
}

model RetryLog {
  id              String   @id @default(cuid())
  failedPaymentId String   @map("failed_payment_id")
  cardFingerprint String?  @map("card_fingerprint") // Track at card level for Visa 15/30d compliance
  attemptNumber   Int      @map("attempt_number")
  success         Boolean
  error           String?
  attemptedAt     DateTime @default(now()) @map("attempted_at")

  failedPayment FailedPayment @relation(fields: [failedPaymentId], references: [id], onDelete: Cascade)

  @@index([failedPaymentId])
  @@index([attemptedAt])
  @@index([cardFingerprint, attemptedAt]) // For Visa compliance queries
  @@map("retry_logs")
}

model EventRaw {
  id             String    @id @default(cuid())
  installationId String    @map("installation_id")
  stripeEventId  String    @unique @map("stripe_event_id")
  eventType      String    @map("event_type")
  rawJson        Json      @map("raw_json")
  retentionDays  Int       @default(90) @map("retention_days") // 540 (18mo) for EU, 90 for US (GDPR/PSD3)
  createdAt      DateTime  @default(now()) @map("created_at")
  deletedAt      DateTime? @map("deleted_at")

  installation Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@index([installationId])
  @@index([stripeEventId])
  @@index([retentionDays, createdAt]) // For GDPR purge queries
  @@map("events_raw")
}

model RecoveredMonthly {
  id              String   @id @default(cuid())
  installationId  String   @map("installation_id")
  month           String   @map("month") // 'YYYY-MM'
  recoveredAmount Decimal  @default(0) @map("recovered_amount") @db.Decimal(10, 2)
  customerCount   Int      @default(0) @map("customer_count")
  merchantFeeOwed Decimal? @map("merchant_fee_owed") @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  installation Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@unique([installationId, month])
  @@index([installationId])
  @@map("recovered_monthly")
}

model UsageTracking {
  id              String    @id @default(cuid())
  installationId  String    @map("installation_id")
  billingMonth    String    @map("billing_month")
  recoveredAmount Decimal   @default(0) @map("recovered_amount") @db.Decimal(10, 2)
  feeOwed         Decimal   @default(0) @map("fee_owed") @db.Decimal(10, 2)
  feePaid         Boolean   @default(false) @map("fee_paid")
  stripeInvoiceId String?   @map("stripe_invoice_id") // Nullable, for Stripe Usage-Based Billing integration later
  invoiceSentAt   DateTime? @map("invoice_sent_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  installation Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@index([installationId])
  @@index([billingMonth])
  @@index([stripeInvoiceId])
  @@map("usage_tracking")
}

model LtdInventory {
  id             String  @id @default(cuid())
  installationId String  @unique @map("installation_id")
  ltdSold        Int     @default(0) @map("ltd_sold") // Updated atomically via transaction lock (prevents race conditions)
  maxCapacity    Int     @default(50) @map("max_capacity")

  installation Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@map("ltd_inventory")
}

model MetricsDaily {
  id                String   @id @default(cuid())
  installationId    String   @map("installation_id")
  date              DateTime @db.Date
  recoveredTotal   Decimal  @default(0) @map("recovered_total") @db.Decimal(12, 2)
  failedTotal       Int      @default(0) @map("failed_total")
  recoveryRate      Decimal  @default(0) @map("recovery_rate") @db.Decimal(5, 2)
  maxCardAttempts30d Int     @default(0) @map("max_card_attempts_30d")
  createdAt         DateTime @default(now()) @map("created_at")

  installation Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@unique([installationId, date])
  @@index([installationId])
  @@map("metrics_daily")
}

// Module 3: Cancel Flow Widget

model CancelFlowConfig {
  id             String   @id @default(cuid())
  installationId String   @unique @map("installation_id")
  enabled        Boolean  @default(true)
  // JSON array of offer objects: [{ type: 'discount'|'pause', discountPercent?, discountMonths?, pauseMonths? }]
  offers         Json     @default("[]")
  // JSON array of reason option strings
  reasonOptions  Json     @default("[\"Too expensive\",\"Not using it enough\",\"Missing features\",\"Switching to competitor\",\"Other\"]")
  brandColor     String   @default("#2563eb") @map("brand_color")
  brandLogo      String?  @map("brand_logo")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  installation Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@map("cancel_flow_configs")
}

model CancelFlowSession {
  id                     String    @id @default(cuid())
  installationId         String    @map("installation_id")
  stripeCustomerId       String    @map("stripe_customer_id")
  stripeSubscriptionId   String    @map("stripe_subscription_id")
  reason                 String?
  reasonText             String?   @map("reason_text")
  // 'discount' | 'pause' | 'none'
  offerType              String?   @map("offer_type")
  offerShown             Boolean   @default(false) @map("offer_shown")
  offerAccepted          Boolean   @default(false) @map("offer_accepted")
  // JSON snapshot of the offer that was shown: { type, discountPercent?, discountMonths?, pauseMonths? }
  offerSnapshot          Json?     @map("offer_snapshot")
  feedbackText           String?   @map("feedback_text")
  competitorName         String?   @map("competitor_name")
  savedAt                DateTime? @map("saved_at")
  cancelledAt            DateTime? @map("cancelled_at")
  createdAt              DateTime  @default(now()) @map("created_at")

  installation Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@index([installationId])
  @@index([stripeSubscriptionId])
  @@index([savedAt])
  @@map("cancel_flow_sessions")
}

// Module 4: Pause Subscription Flow

model PausedSubscription {
  id                  String    @id @default(cuid())
  installationId       String    @map("installation_id")
  stripeCustomerId    String    @map("stripe_customer_id")
  stripeSubscriptionId String   @unique @map("stripe_subscription_id")
  pausedAt             DateTime @map("paused_at")
  resumeAt             DateTime @map("resume_at")
  resumedAt            DateTime? @map("resumed_at")
  // 'cancel_flow' when paused via cancel flow widget; 'manual' when paused in Stripe Dashboard / API
  pauseSource          String   @map("pause_source")

  installation Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@index([installationId])
  @@index([stripeCustomerId])
  @@map("paused_subscriptions")
}

// Module 6: Reactivation Campaigns

model ChurnedCustomer {
  id                  String    @id @default(cuid())
  installationId      String    @map("installation_id")
  stripeCustomerId    String    @map("stripe_customer_id")
  customerEmail       String    @map("customer_email")
  cancelledAt         DateTime  @map("cancelled_at")
  // reason forwarded from CancelFlowSession if one exists
  cancelReason        String?   @map("cancel_reason")
  reactivatedAt       DateTime? @map("reactivated_at")
  // 'reactivation_email' | 'direct' | 'other'
  reactivationSource  String?   @map("reactivation_source")

  installation        Installation        @relation(fields: [installationId], references: [id], onDelete: Cascade)
  reactivationEmails  ReactivationEmail[]

  @@index([installationId])
  @@index([stripeCustomerId])
  @@index([customerEmail])
  @@map("churned_customers")
}

model ReactivationCampaign {
  id             String   @id @default(cuid())
  installationId String   @unique @map("installation_id")
  enabled        Boolean  @default(false)
  // JSON array: [{ dayOffset: number, subject: string, body: string, offerType: 'percent_off'|'none', offerValue: number }]
  emails         Json     @default("[]")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  installation Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@map("reactivation_campaigns")
}

model ReactivationEmail {
  id                  String    @id @default(cuid())
  churnedCustomerId   String    @map("churned_customer_id")
  // index into ReactivationCampaign.emails[] array
  emailIndex          Int       @map("email_index")
  sentAt              DateTime  @default(now()) @map("sent_at")
  opened              Boolean   @default(false)
  clicked             Boolean   @default(false)
  reactivatedFromThis Boolean   @default(false) @map("reactivated_from_this")

  churnedCustomer ChurnedCustomer @relation(fields: [churnedCustomerId], references: [id], onDelete: Cascade)

  @@unique([churnedCustomerId, emailIndex])
  @@index([churnedCustomerId])
  @@map("reactivation_emails")
}

